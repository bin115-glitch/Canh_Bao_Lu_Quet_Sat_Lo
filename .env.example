# Dữ liệu
FORECAST_HOURS=6
NCHMF_COOKIE=
OUTPUT_DIR=outputs

# Google AI Studio / Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Gmail SMTP: dùng App Password, không dùng mật khẩu Gmail chính.
SEND_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_APP_PASSWORD=
MAIL_FROM=your-account@gmail.com
MAIL_TO=recipient@example.com
